{
  "name": "moirai-sports-engine",
  "version": "1.0.0",
  "description": "MoirAI Sports Engine — Plataforma de análise estatística esportiva de alta precisão. Desenvolvido por MADev.",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:migrate": "tsx scripts/migrate.ts",
    "db:seed": "tsx scripts/seed.ts",
    "db:setup": "npm run db:up && sleep 3 && npm run db:migrate && npm run db:seed",
    "db:reset": "npm run db:down && npm run db:setup"
  },
  "dependencies": {
    "decimal.js": "^10.4.3",
    "dotenv": "^17.4.2",
    "next": "^14.2.0",
    "pg": "^8.21.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@types/node": "^20.19.41",
    "@types/pg": "^8.20.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.5.0",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.19",
    "tsx": "^4.22.3",
    "typescript": "^5.4.0"
  }
}
